{
  "extends": "@tsconfig/node24/tsconfig.json",
  "include": [
    "vitest.config.*",
    "eslint.config.*",
    "prettier.config.*",
    ".vitepress/config.*"
  ],
  "compilerOptions": {
    "composite": true,
    "module": "preserve",
    "moduleResolution": "bundler",
    "types": ["node"],
    "noEmit": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo"
  }
}
